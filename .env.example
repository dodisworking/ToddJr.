# Copy to `.env` for local development (same variable names as Railway).
# Never commit `.env` — it is gitignored.
#
# Railway: Project → your Todd service → Variables — add at least:
#   ANTHROPIC_API_KEY   (Claude — required for hunts and most Test Lab modes)
#   OPENAI_API_KEY      (OpenAI — optional; OpenAI Test Lab / Claude-vs-OpenAI need it)
# Redeploy after changing variables. Keys are read only on the server, never from the browser.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Or skip this and use a one-line file openai.key next to package.json (see openai.key.example).

# Server listen (default PORT=3456 so 3000 can stay free for other tools). Railway sets PORT.
# PORT=3000
# HOST=127.0.0.1

# Allow browsers on http://localhost:* / http://127.0.0.1:* to call this API (CORS).
# • Local Todd + Live Server / another port: LOCAL_DEV_CORS=1 here.
# • Deployed API on Railway + static/local HTML: set LOCAL_DEV_CORS=1 on Railway, redeploy,
#   then in public/index.html set <meta name="todd-api-base" content="https://YOUR-SERVICE.up.railway.app"> (no /api suffix).
LOCAL_DEV_CORS=1

# Optional: single fixed browser origin (e.g. hosted static site)
# CORS_ORIGIN=https://your-app.pages.dev

# ── PERSISTENT STORAGE (Railway Volume) ──────────────────────────────────────
# Railway's filesystem is ephemeral — files are wiped on every restart/redeploy.
# To persist Isaac saves, learnings (juice training data), and Dr. Todd reports:
#
#   1. Railway dashboard → your Todd service → Volumes → Add Volume
#      Mount path: /data   (or any path you choose)
#   2. Add this variable (matching your mount path):
#
# PERSIST_DIR=/data
#
# Without this, all saves are lost on restart. Uploads are always temporary (fine).
# ─────────────────────────────────────────────────────────────────────────────

# Optional overrides (OpenAI model compare)
# OPENAI_MODEL=gpt-4.1
# OPENAI_MODEL_CHEAP=gpt-4.1-mini
# HTTP timeout for each OpenAI request in ms (default 1200000 = 20 min). Raise for huge native-PDF batches.
# OPENAI_TIMEOUT_MS=1800000
# Set to 1 only if the API rejects json_schema structured output (rare); Todd will fall back to prompt-only JSON.
# OPENAI_DISABLE_STRUCTURED=1
